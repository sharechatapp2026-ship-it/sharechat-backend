generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  username       String          @unique
  email          String          @unique
  passwordHash   String
  fullName       String?
  profilePicture String?
  bio            String?
  birthYear      Int?
  gender         String?
  language       String          @default("ar")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  city           String?
  country        String?
  displayStyle   String?
  educationLevel String?
  interests      String[]
  workField      String?
  emailVerified  Boolean         @default(false)
  notifications  notifications[]
  push_tokens    push_tokens[]
  sessions       Session[]
  verifications  Verification[]

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  expiresAt    DateTime
  deviceInfo   Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model Verification {
  id         String    @id @default(uuid())
  userId     String
  email      String
  code       String
  type       String    @default("email_verification")
  expiresAt  DateTime
  verifiedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])

  @@map("verifications")
}

model notifications {
  id        String   @id
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  users     User     @relation(fields: [userId], references: [id])
}

model push_tokens {
  id         String   @id
  userId     String
  token      String   @unique
  deviceType String
  lastUsed   DateTime @default(now())
  createdAt  DateTime @default(now())
  users      User     @relation(fields: [userId], references: [id])
}
